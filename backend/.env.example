# Optional live cinema showtimes provider. Without these, the app shows demo fallback showtimes.
MOVIEGLU_CLIENT=
MOVIEGLU_API_KEY=
MOVIEGLU_AUTH=
MOVIEGLU_TERRITORY=IN
MOVIEGLU_API_VERSION=v200
MOVIEGLU_GEOLOCATION=12.9716;77.5946

QR_TARGET_URL=https://example.com
QR_DISPLAY_NAME=Example dynamic QR code
